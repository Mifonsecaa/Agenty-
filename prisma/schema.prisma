generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  businesses    Business[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id           String        @id @default(cuid())
  name         String
  phone        String?       @unique
  config       Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  dailyMetrics DailyMetric[]
  knowledgeItems KnowledgeItem[]
  conversations  Conversation[]
}

model DailyMetric {
  id               String   @id @default(cuid())
  businessId       String
  date             DateTime // Fecha truncada (sólo día)
  messagesReceived Int      @default(0)
  messagesSent     Int      @default(0)
  aiResponses      Int      @default(0)
  tokensUsed       Int      @default(0)
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
}

model Customer {
  id           String        @id @default(cuid())
  phone        String        @unique
  name         String?
  createdAt    DateTime      @default(now())
  reservations Reservation[]
  conversations Conversation[]
}

model Conversation {
  id           String    @id @default(cuid())
  businessId   String
  customerId   String
  status       String    @default("ACTIVE") // ACTIVE, HANDOFF, RESOLVED
  channel      String    @default("WHATSAPP") // WHATSAPP, WEB, INSTAGRAM
  lastMessageAt DateTime @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([businessId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // user, assistant, system
  content        String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Reservation {
  id         String   @id @default(cuid())
  startTime  DateTime
  endTime    DateTime
  status     String   @default("CONFIRMED")
  businessId String
  customerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId, startTime])
}

model KnowledgeItem {
  id         String   @id @default(cuid())
  businessId String
  content    String
  embedding  Unsupported("vector(1536)")?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}
