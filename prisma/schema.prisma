generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role       @default(USERDEFAULT)
  trialStartedAt DateTime?
  trialBusinessId String?
  accounts      Account[]
  businesses    Business[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id                         String                  @id @default(cuid())
  name                       String
  phone                      String?                 @unique
  telegramBotToken           String?
  telegramBotUsername        String?
  whatsappPhoneNumberId      String?
  whatsappAccessToken        String?
  whatsappWebhookVerifyToken String?
  instagramPageId            String?
  instagramAppSecret         String?
  instagramAccessToken       String?
  config                     Json
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  userId                     String
  user                       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations              Conversation[]
  dailyMetrics               DailyMetric[]
  knowledgeIngestionJobs     KnowledgeIngestionJob[]
  knowledgeItems             KnowledgeItem[]
  reservations               Reservation[]
}

model DailyMetric {
  id               String   @id @default(cuid())
  businessId       String
  date             DateTime
  messagesReceived Int      @default(0)
  messagesSent     Int      @default(0)
  aiResponses      Int      @default(0)
  tokensUsed       Int      @default(0)
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
}

model Customer {
  id                String         @id @default(cuid())
  phone             String         @unique
  name              String?
  aiProfile         String?
  lastProfileUpdate DateTime?
  createdAt         DateTime       @default(now())
  conversations     Conversation[]
  reservations      Reservation[]
}

model Conversation {
  id            String    @id @default(cuid())
  businessId    String
  customerId    String
  status        String    @default("ACTIVE")
  channel       String    @default("WHATSAPP")
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([businessId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Reservation {
  id         String   @id @default(cuid())
  startTime  DateTime
  endTime    DateTime
  status     String   @default("CONFIRMED")
  details    String?
  metadata   Json?    @default("{}")
  businessId String
  customerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId, startTime])
}

model KnowledgeItem {
  id         String                 @id @default(cuid())
  businessId String
  content    String
  embedding  Unsupported("vector")?
  metadata   Json                   @default("{}")
  createdAt  DateTime               @default(now())
  business   Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model KnowledgeIngestionJob {
  id          String                      @id @default(cuid())
  businessId  String
  status      KnowledgeIngestionJobStatus @default(PENDING)
  payload     Json
  fingerprint String?
  attempts    Int                         @default(0)
  maxAttempts Int                         @default(3)
  chunkCount  Int?
  lastError   String?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  nextRunAt   DateTime                    @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  business    Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([status, nextRunAt])
  @@index([fingerprint])
}

enum KnowledgeIngestionJobStatus {
  PENDING
  PROCESSING
  RETRY
  COMPLETED
  FAILED
  DLQ
}

// Roles for application users
enum Role {
  ADMIN
  USERDEFAULT
  USERPRO
  USERTRY
}

model TrialAction {
  id          String   @id @default(cuid())
  adminId     String
  targetUserId String
  action      String
  details     String?  @default("")
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
}

