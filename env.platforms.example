# ─── Variables de Entorno para Plataformas de Mensajería ────────────────────
# Añade estas variables a tu archivo .env

# ─── META (WhatsApp + Instagram) ─────────────────────────────────────────────
META_APP_ID=tu_app_id_de_meta
META_APP_SECRET=tu_app_secret_de_meta
META_WEBHOOK_VERIFY_TOKEN=un_token_secreto_que_tu_inventas

# ─── URLs ─────────────────────────────────────────────────────────────────────
# En producción (Vercel):
NEXTAUTH_URL=https://tu-dominio.com

# En local con túnel (recomendado):
PUBLIC_BASE_URL=https://tu-subdominio.ngrok-free.app
# Opcional: si tu API local de ngrok no está en el puerto por defecto
# NGROK_API_URL=http://127.0.0.1:4040

# ─── Redis (rate-limit distribuido) ───────────────────────────────────────────
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=agenty:traffic
REDIS_TIMEOUT_MS=1200

# ─── Worker de transcripción de audio ─────────────────────────────────────────
TRANSCRIPTION_WORKER_TOKEN=un_token_worker
TRANSCRIPTION_WORKER_BASE_URL=http://localhost:3001
TRANSCRIPTION_WORKER_BATCH_SIZE=4
TRANSCRIPTION_WORKER_POLL_MS=2500
TRANSCRIPTION_WORKER_IDLE_MS=5000
TRANSCRIPTION_INLINE_FALLBACK=true

# ─── Chat Streaming SSE ───────────────────────────────────────────────────────
CHAT_STREAM_CHUNK_SIZE=64
CHAT_STREAM_DELAY_MS=0

# ─── NOTAS DE CONFIGURACIÓN ───────────────────────────────────────────────────
# Las credenciales de WhatsApp, Telegram e Instagram se guardan
# directamente en la base de datos por negocio, NO en el .env.
# Solo los secretos globales de la APP van aquí.

# WhatsApp Webhook URL a configurar en Meta Developers:
#   https://tu-dominio.com/api/webhooks/whatsapp

# Instagram Webhook URL a configurar en Meta Developers:
#   https://tu-dominio.com/api/webhooks/instagram

# Telegram Webhook se registra automáticamente al conectar el bot.
# URL usada: https://tu-dominio.com/api/telegram/webhook?businessId=xxx
