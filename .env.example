# Database
DATABASE_URL="postgresql://user:password@localhost:5432/agenty_db?schema=public"

# Supabase (DB/Storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="knowledge-files"

# Auth
NEXTAUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# AI Providers
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AIza..."
GITHUB_TOKEN="ghp_..."

# WhatsApp Integration
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="agenty_secret_key_123"

# Knowledge Queue Worker
KNOWLEDGE_WORKER_TOKEN=""
KNOWLEDGE_WORKER_BASE_URL="http://localhost:3001"
KNOWLEDGE_WORKER_BATCH_SIZE="5"
KNOWLEDGE_WORKER_POLL_MS="2500"
KNOWLEDGE_WORKER_IDLE_MS="5000"
KNOWLEDGE_INLINE_KICKOFF="true"

# Knowledge Queue Cleanup Worker
KNOWLEDGE_CLEANUP_RETENTION_DAYS="14"
KNOWLEDGE_CLEANUP_INTERVAL_MS="86400000"
KNOWLEDGE_CLEANUP_BUSINESS_ID=""

# Traffic Control (In-Memory)
CHAT_RATE_LIMIT_MAX="30"
CHAT_RATE_LIMIT_WINDOW_MS="60000"
CHAT_DEMO_MAX_CONCURRENT="2"
CHAT_AGENT_MAX_CONCURRENT="2"
CHAT_STREAM_CHUNK_SIZE="64"
CHAT_STREAM_DELAY_MS="0"

# Distributed Traffic Control (Redis)
REDIS_ENABLED="false"
REDIS_URL="redis://localhost:6379"
REDIS_PREFIX="agenty:traffic"
REDIS_TIMEOUT_MS="1200"

KNOWLEDGE_POST_RATE_LIMIT_MAX="12"
KNOWLEDGE_POST_RATE_LIMIT_WINDOW_MS="60000"
KNOWLEDGE_POST_MAX_CONCURRENT="2"

TELEGRAM_RATE_LIMIT_MAX="25"
TELEGRAM_RATE_LIMIT_WINDOW_MS="60000"
TELEGRAM_MAX_CONCURRENT_PER_CHAT="1"

WHATSAPP_RATE_LIMIT_MAX="25"
WHATSAPP_RATE_LIMIT_WINDOW_MS="60000"
WHATSAPP_MAX_CONCURRENT_PER_CHAT="1"

# Audio Transcription Queue Worker
TRANSCRIPTION_WORKER_TOKEN=""
TRANSCRIPTION_WORKER_BASE_URL="http://localhost:3001"
TRANSCRIPTION_WORKER_BATCH_SIZE="4"
TRANSCRIPTION_WORKER_POLL_MS="2500"
TRANSCRIPTION_WORKER_IDLE_MS="5000"
TRANSCRIPTION_JOB_MAX_ATTEMPTS="3"
TRANSCRIPTION_INLINE_FALLBACK="true"

# AI Cache
AI_RAG_CACHE_TTL_MS="120000"
AI_RESPONSE_CACHE_TTL_MS="45000"
AI_RAG_CACHE_MAX_ENTRIES="500"
AI_RESPONSE_CACHE_MAX_ENTRIES="300"
AI_BUSINESS_CACHE_TTL_MS="45000"

# RAG Quality Tuning
RAG_CHUNK_SIZE="700"
RAG_CHUNK_OVERLAP="120"
RAG_MIN_CHUNK_CHARS="60"
RAG_RETRIEVAL_CANDIDATES="10"
RAG_RETRIEVAL_TOP_K="4"
RAG_CONTEXT_MAX_CHARS="2600"
RAG_CONTEXT_MAX_TOKENS="900"
RAG_MIN_VECTOR_SIMILARITY="0.6"
RAG_RETRIEVAL_CACHE_TTL_MS="90000"
RAG_RETRIEVAL_CACHE_MAX_ENTRIES="600"
RAG_KNOWLEDGE_PRESENCE_TTL_MS="90000"
RAG_ENABLE_HEURISTIC_SKIP="true"
RAG_MULTI_QUERY_ENABLED="true"
RAG_MULTI_QUERY_MAX_VARIANTS="2"
RAG_TOOL_RETRIEVAL_CANDIDATES="12"
RAG_TOOL_TOP_K="4"
RAG_TOOL_MIN_SCORE="0.58"

# Metrics API Optimization
METRICS_CACHE_TTL_MS="20000"
METRICS_RATE_LIMIT_MAX="40"
METRICS_RATE_LIMIT_WINDOW_MS="60000"

